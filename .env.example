# ─── MWS ADMIN — Environment Variables ───────────────────────────────────────
# Copy this to .env.local for local dev
# For production, add these in Vercel Dashboard → Settings → Environment Variables

# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated list of channel IDs (e.g. -1001234567890,-1009876543210)
TARGET_CHANNELS=-1001234567890

# Your Telegram alerts channel invite link
ALERTS_CHANNEL_LINK=https://t.me/your_channel

# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal Access Token with repo read/write permissions
GITHUB_TOKEN=ghp_yourtoken

# Format: username/reponame
REPO_NAME=yourusername/yourrepo

# ── TMDB ──────────────────────────────────────────────────────────────────────
TMDB_API_KEY=your_tmdb_api_key

# ── Website ───────────────────────────────────────────────────────────────────
WEBSITE_URL=https://yourwebsite.com

# ── Auth ──────────────────────────────────────────────────────────────────────
# Strong random secret for JWT signing (use: openssl rand -hex 32)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars

# Users JSON array — roles: "owner" | "auth"
# Generate password hash: node -e "const b=require('bcryptjs');console.log(b.hashSync('yourpassword',10))"
MWS_USERS=[{"id":"1","username":"admin","passwordHash":"$2b$10$REPLACE_WITH_REAL_HASH","role":"owner"}]
